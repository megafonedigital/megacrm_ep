############################################################
# MegaCRM — env do docker-compose
#
# 1) cp deploy/.env.example .env
# 2) node deploy/generate-keys.mjs        (preenche os segredos)
# 3) Preencha as URLs públicas abaixo
############################################################

# ─── Segredos (gerados pelo generate-keys.mjs — deixe vazios) ───
POSTGRES_PASSWORD=
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=
SECRET_KEY_BASE=
PG_META_CRYPTO_KEY=
DASHBOARD_PASSWORD=

# ─── URLs públicas (ajuste para seu domínio) ───
# URL pública do app (frontend)
SITE_URL=https://crm.seudominio.com
# URL pública da API Supabase (kong) — crie um subdomínio no EasyPanel
API_EXTERNAL_URL=https://api.seudominio.com
SUPABASE_PUBLIC_URL=https://api.seudominio.com
# Redirects extras permitidos no auth (separados por vírgula)
ADDITIONAL_REDIRECT_URLS=

# ─── Banco ───
POSTGRES_DB=postgres

# ─── Studio / Dashboard (protegido por basic-auth no Kong) ───
DASHBOARD_USERNAME=megafone
STUDIO_DEFAULT_ORGANIZATION=Megafone
STUDIO_DEFAULT_PROJECT=MegaCRM

# ─── Portas no host (EasyPanel mapeia domínios direto no serviço) ───
WEB_PORT=3000
KONG_HTTP_PORT=8000

# ─── Auth / e-mail ───
# Com autoconfirm true, convites de usuário funcionam sem SMTP.
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
DISABLE_SIGNUP=false
JWT_EXPIRY=3600
# SMTP (opcional — necessário para e-mails de convite/recuperação)
SMTP_ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=MegaCRM

# ─── Worker de broadcasts ───
WORKER_TICK_INTERVAL_MS=5000
WORKER_DRAIN_CONCURRENCY=100
WORKER_DRAIN_BATCH_SIZE=300
WORKER_ENGINE_TIMEOUT_MS=800
WORKER_PG_POOL_SIZE=20

# ─── Cron sidecar (crons não-broadcast do app) ───
CRON_FAST_INTERVAL=5
CRON_MEDIUM_INTERVAL=15
CRON_SLOW_INTERVAL=60
CRON_BROADCAST_FALLBACK=false

# ─── Diversos ───
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
FUNCTIONS_VERIFY_JWT=false
STORAGE_TENANT_ID=megacrm
REGION=local
GLOBAL_S3_BUCKET=stub
REALTIME_DB_ENC_KEY=supabaserealtime000000000000000
